{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "embed assets",
            "type": "shell",
            "command": "py",
            "args": ["${workspaceFolder}/embed.py"],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "build debug",
            "type": "shell",
            "command": "C:/msys64/ucrt64/bin/x86_64-w64-mingw32-g++.exe",
            "args": [
                "-g",
                "${workspaceFolder}/src/main.cpp",
                "-o",
                "${workspaceFolder}/src/main.exe",
                "-I", "C:/msys64/ucrt64/include",
                "-I", "${workspaceFolder}/src",
                "-L", "C:/msys64/ucrt64/lib",
                "C:/msys64/ucrt64/lib/libraylib_static.a",
                "-lopengl32",
                "-lgdi32",
                "-lwinmm",
                "-static-libgcc",
                "-static-libstdc++",
                "-mwindows"
            ],
            "options": {
                "shell": {
                    "executable": "cmd.exe",
                    "args": ["/c"]
                }
            },
            "dependsOn": ["embed assets"],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "build release",
            "type": "shell",
            "command": "C:/msys64/ucrt64/bin/x86_64-w64-mingw32-g++.exe",
            "args": [
                "-O2",
                "${workspaceFolder}/src/main.cpp",
                "-o",
                "${workspaceFolder}/src/main.exe",
                "-I", "C:/msys64/ucrt64/include",
                "-I", "${workspaceFolder}/src",
                "-L", "C:/msys64/ucrt64/lib",
                "C:/msys64/ucrt64/lib/libraylib_static.a",
                "-lopengl32",
                "-lgdi32",
                "-lwinmm",
                "-static-libgcc",
                "-static-libstdc++",
                "-mwindows"
            ],
            "options": {
                "shell": {
                    "executable": "cmd.exe",
                    "args": ["/c"]
                }
            },
            "dependsOn": ["embed assets"],
            "group": "build",
            "problemMatcher": ["$gcc"]
        }
    ]
}